{
  "name": "data-whisper",
  "version": "1.0.0",
  "description": "Production-grade Natural Language to SQL engine",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "setupFiles": [
      "<rootDir>/src/__test-setup__.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/server.ts",
      "!src/__test-setup__.ts"
    ],
    "coverageDirectory": "coverage",
    "moduleNameMapper": {
      "^ioredis$": "<rootDir>/node_modules/ioredis-mock/lib/index.js"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.2",
    "ioredis": "^5.3.2",
    "node-sql-parser": "^4.18.0",
    "openai": "^4.47.1",
    "pg": "^8.11.5",
    "sql-formatter": "^15.7.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "ioredis-mock": "^8.13.1",
    "jest": "^30.3.0",
    "pino-pretty": "^13.1.3",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
