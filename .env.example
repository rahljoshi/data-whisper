# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Provide either a full connection string OR individual fields
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# Optional individual fields (used if DATABASE_URL is not set)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=mydb
# DB_USER=user
# DB_PASSWORD=password

# Connection pool settings
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=
# REDIS_TLS=false

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=512
OPENAI_TEMPERATURE=0

# ─── Query Engine ─────────────────────────────────────────────────────────────
QUERY_TIMEOUT_MS=5000
QUERY_MAX_ROWS=100
CACHE_TTL_SECONDS=3600
SCHEMA_REFRESH_INTERVAL_MS=600000

# ─── Security ─────────────────────────────────────────────────────────────────
# Maximum length of user question input
MAX_QUESTION_LENGTH=2000

# Comma-separated list of column name patterns to hide from LLM
SENSITIVE_COLUMN_PATTERNS=password,password_hash,secret,token,api_key,private_key,salt,otp,ssn,credit_card

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# ─── Schema ───────────────────────────────────────────────────────────────────
# Comma-separated list of PostgreSQL schemas to introspect (default: public)
DB_SCHEMAS=public
