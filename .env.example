# --- Server -------------------------------------------------------------------
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# --- PostgreSQL ---------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/mydb
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# --- Redis --------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- Multi-Provider LLM -------------------------------------------------------
# Default provider. Must be one of: openai | anthropic | gemini
LLM_PROVIDER=anthropic
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4o

# Google Gemini
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-1.5-pro

# --- Query Engine -------------------------------------------------------------
QUERY_MODE=READ_ONLY
QUERY_TIMEOUT_MS=5000
QUERY_MAX_ROWS=100
CACHE_TTL_SECONDS=3600
SCHEMA_REFRESH_INTERVAL_MS=600000
PENDING_WRITE_TTL_SECONDS=300

# --- Security -----------------------------------------------------------------
MAX_QUESTION_LENGTH=2000
SENSITIVE_COLUMN_PATTERNS=password,password_hash,secret,token,api_key,private_key,salt,otp,ssn,credit_card

# --- Rate Limiting ------------------------------------------------------------
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# --- Schema -------------------------------------------------------------------
DB_SCHEMAS=public

# --- Query Cost Estimation ----------------------------------------------------
QUERY_COST_THRESHOLD=10000
SEQ_SCAN_ROW_THRESHOLD=100000
